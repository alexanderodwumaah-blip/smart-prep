{
  "version": 2,
  "builds": [
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/client/index.html"
    },
    {
      "src": "/app.js",
      "dest": "/client/app.js"
    },
    {
      "src": "/(.*\\.(js|css|html|ico|png|jpg|jpeg|svg|webp|woff|woff2|ttf|eot))",
      "dest": "/client/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/client/index.html"
    }
  ]
}
